# 环境变量配置文件
# 复制此文件为 .env 并填入实际的值

# Supabase 配置
# 创建 Supabase 项目后，从 Dashboard 获取这些值
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"
DATABASE_URL="postgresql://user:password@your-project.supabase.co:5432/postgres"

# SEC EDGAR API 配置
# 用于获取财报数据
SEC_USER_AGENT="your-email@example.com/EarningsPulse"

# Alpha Vantage API 配置
# 已注册 Key
ALPHA_VANTAGE_API_KEY="HK0R2R4E0W79IM4L"

# FinViz API 配置
# 注册后获取：https://finviz.com/api.html
FINVIZ_API_KEY="your-api-key"

# Yahoo Finance API 配置（如果需要）
# YAHOO_FINANCE_API_KEY="your-api-key"

# Telegram Bot 配置（用于推送通知）
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# 应用配置
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EarningsPulse"
